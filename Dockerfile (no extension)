# ==============================================================================
# Dockerfile — Manufacturing Defect Detection API
# ==============================================================================
# Base: python:3.9-slim (minimal Debian, compatible with TensorFlow wheels)
# Exposes the FastAPI inference service on port 8000.
# ==============================================================================
FROM python:3.9-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# curl is used by the HEALTHCHECK below
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies BEFORE copying app code so Docker caches this
# expensive layer and only re-runs it when requirements.txt changes.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code and the trained model artifact
COPY api_server.py kafka_client.py ./

# Copy the trained model (produced by running the notebook end-to-end).
# If defect_model.h5 is not yet present, build the image after running
# the notebook and saving the model:
#     model.save("defect_model.h5")
COPY defect_model.h5 ./

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

CMD ["uvicorn", "api_server:app", "--host", "0.0.0.0", "--port", "8000"]
